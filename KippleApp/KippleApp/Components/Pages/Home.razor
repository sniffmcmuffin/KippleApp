@page "/"
@using KippleApp.Services
@layout MainLayout
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject ThemeService ThemeService

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

<p>Welcome to your new app.</p>

<hr />
<h4>@ThemeService.CurrentTheme</h4>
<h3>Theme test</h3>

<button class="btn btn-primary" @onclick='() => SetTheme("theme-light")'>Light</button>
<button class="btn btn-primary" @onclick='() => SetTheme("theme-dark")'>Dark</button>

@code {
    private async Task SetTheme(string theme)
    {
        ThemeService.SetTheme(theme);
        await JS.InvokeVoidAsync("setTheme", theme);
    }
}